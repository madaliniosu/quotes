---
interface Props {
  active?: 'home' | 'timeline' | 'about';
}
const { active } = Astro.props;
---

<nav>
  <a href="/" class="site-name" aria-current={active === 'home' ? 'page' : undefined}>Quotes</a>
  <div class="links">
    <a
      href="/timeline"
      class:list={[{ active: active === 'timeline' }]}
      aria-current={active === 'timeline' ? 'page' : undefined}
    >Timeline</a>
    <a
      href="/about"
      class:list={[{ active: active === 'about' }]}
      aria-current={active === 'about' ? 'page' : undefined}
    >About</a>
  </div>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .site-name {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .links {
    display: flex;
    gap: 2rem;
  }

  .links a {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color 0.15s;
  }

  .links a:hover,
  .links a.active {
    color: var(--color-text);
  }

  .links a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
