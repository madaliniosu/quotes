---
---

<nav class="quote-nav" aria-label="Quote navigation">
  <button type="button" id="btn-prev" aria-label="Previous quote">&#8592; Prev</button>
  <button type="button" id="btn-random" aria-label="Random quote">Random</button>
  <button type="button" id="btn-next" aria-label="Next quote">Next &#8594;</button>
</nav>

<style>
  .quote-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem 2rem 2.5rem;
  }

  button {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    padding: 0.5rem 1.25rem;
    border-radius: 2rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    letter-spacing: 0.01em;
  }

  button:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  #btn-random {
    border-color: transparent;
    color: var(--color-muted);
  }

  #btn-random:hover {
    color: var(--color-text);
    border-color: var(--color-border);
  }
</style>
