---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getQuotes, formatMonthYear } from '../lib/notion';
import type { Quote } from '../lib/notion';

let quotes: Quote[] = [];
let fetchError = false;
try {
  quotes = await getQuotes();
} catch (e) {
  fetchError = true;
  console.error('Failed to fetch quotes from Notion:', e);
}

// Group quotes by YYYY-MM
const grouped = new Map<string, typeof quotes>();
for (const q of quotes) {
  const key = q.date || 'Undated';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(q);
}

// Sort groups descending by date; push "Undated" to the end
const sortedGroups = [...grouped.entries()].sort(([a], [b]) => {
  if (a === 'Undated') return 1;
  if (b === 'Undated') return -1;
  return b.localeCompare(a);
});

// Build flat index map so timeline links go to /#<index>
const indexMap = new Map(quotes.map((q, i) => [q.id, i]));
---

<Layout title="Timeline — Quotes">
  <Nav active="timeline" />
  <main>
    <h1>Timeline</h1>
    {fetchError ? (
      <p class="status-msg">Unable to load quotes right now. Please try again later.</p>
    ) : quotes.length === 0 ? (
      <p class="status-msg">No quotes yet.</p>
    ) : (
      sortedGroups.map(([key, qs]) => (
        <section>
          <h2>{formatMonthYear(key)}</h2>
          <ul>
            {qs.map((q) => (
              <li>
                <a href={`/#${indexMap.get(q.id)}`}>
                  <span class="text">&#8220;{q.text}&#8221;</span>
                  <span class="author">— {q.author}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}
  </main>
</Layout>

<style>
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 2rem 4rem;
    width: 100%;
  }

  h1 {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 3rem;
  }

  section {
    margin-bottom: 2.5rem;
  }

  h2 {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  li a {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: opacity 0.15s;
  }

  li a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  li:last-child a {
    border-bottom: none;
  }

  li a:hover {
    opacity: 0.65;
  }

  .text {
    font-family: var(--font-quote);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.55;
  }

  .author {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .status-msg {
    color: var(--color-muted);
    font-family: var(--font-ui);
  }
</style>
